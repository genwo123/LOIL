# ============================================
# 로일(LoIl) 환경변수 설정
# ============================================
# 
# 사용법:
# 1. 이 파일을 .env로 복사
# 2. 각 값을 실제 값으로 변경
# 3. .env 파일은 절대 Git에 커밋하지 마세요!
#
# ============================================

# ============================================
# Discord Bot
# ============================================
# Discord 봇 설정
# https://discord.com/developers/applications 에서 발급

DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_GUILD_ID=your_primary_guild_id

# ============================================
# Database
# ============================================

# MySQL (추천 - 개발자가 경험 있음)
DATABASE_URL=mysql://username:password@localhost:3306/loil_db

# 또는 PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost:5432/loil_db

# 개발 환경 (Docker)
DEV_DATABASE_URL=mysql://loil_user:loil_password@localhost:3306/loil_dev

# 프로덕션 (클라우드)
# Supabase 예시
# DATABASE_URL=postgresql://user:pass@db.supabase.co:5432/postgres

# PlanetScale 예시 (MySQL)
# DATABASE_URL=mysql://user:pass@aws.connect.psdb.cloud/loil?ssl={"rejectUnauthorized":true}

# ============================================
# AI APIs
# ============================================

# Gemini (Google) - 메인 AI (무료!)
# 발급: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (백업 AI) - 무료
# 발급: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (선택사항)
# OPENAI_API_KEY=your_openai_key_here

# ============================================
# Game APIs
# ============================================

# 로스트아크 API
# 발급: https://developer-lostark.game.onstove.com/
LOSTARK_API_KEY=your_lostark_api_key_here

# ============================================
# Google APIs
# ============================================

# Google Sheets API
# Google Service Account 키 파일 경로
# 발급: https://console.cloud.google.com/
GOOGLE_CREDENTIALS_FILE=service-account-key.json
GOOGLE_SPREADSHEET_URL=your_spreadsheet_url

# ============================================
# 카카오톡 Bot (프리미엄)
# ============================================

# 카카오톡 챗봇 API
# 발급: https://developers.kakao.com/
KAKAO_API_KEY=your_kakao_api_key
KAKAO_BOT_ID=your_kakao_bot_id

# ============================================
# Premium & Monetization
# ============================================

# 화이트리스트 (영구 무료)
# Discord ID를 쉼표로 구분
PREMIUM_GUILDS=123456789,987654321
FREE_USERS=your_discord_user_id,friend_discord_id

# 결제 시스템 (차후 추가)
# STRIPE_API_KEY=your_stripe_key
# STRIPE_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# Web (선택사항)
# ============================================

# 웹사이트 URL
WEB_URL=https://loil.kr
API_URL=https://api.loil.kr

# Google AdSense (광고)
# GOOGLE_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx

# ============================================
# Logging & Monitoring
# ============================================

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Sentry (에러 추적) - 선택사항
# SENTRY_DSN=your_sentry_dsn

# ============================================
# Development
# ============================================

# 개발 모드 (True/False)
DEBUG=True

# 테스트 모드
TEST_MODE=False

# ============================================
# Server Configuration
# ============================================

# 서버 포트
PORT=8000

# 타임존
TIMEZONE=Asia/Seoul

# ============================================
# Cache & Redis (선택사항)
# ============================================

# Redis (캐싱용)
# REDIS_URL=redis://localhost:6379

# ============================================
# Email (선택사항)
# ============================================

# SMTP 설정 (알림 이메일용)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ============================================
# API Key Management (신규!)
# ============================================

# 무료 유저 최대 API 키 개수
MAX_API_KEYS_FREE=3

# 프리미엄 유저 최대 API 키 개수
MAX_API_KEYS_PREMIUM=5

# API Rate Limit (요청/분)
API_RATE_LIMIT=60

# ============================================
# 참고사항
# ============================================
#
# 보안:
# - .env 파일은 절대 Git에 커밋하지 마세요
# - API 키는 절대 공개하지 마세요
# - 프로덕션과 개발 환경을 분리하세요
#
# 테스트:
# - 모든 키를 발급받았는지 확인
# - python bot/main.py 실행 전 확인
#
# 문제 발생 시:
# - 키 형식이 올바른지 확인
# - 따옴표 없이 입력했는지 확인
# - 공백이 없는지 확인
#
